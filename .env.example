# Copie este arquivo para ".env" e preencha os valores.
# start-dev.sh gera um .env de desenvolvimento automaticamente se ele não existir.
# start-prod.sh EXIGE que todas as variáveis marcadas como obrigatórias em produção estejam preenchidas.

# ---- Frontend / NextAuth ----
NEXTAUTH_URL=http://localhost:3000
DJANGO_API_URL=http://django:8000
# Obrigatório em produção. Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=

# ---- Django ----
# Obrigatório em produção.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# ---- MySQL ----
# Obrigatório em produção. Deixe todas em branco para o backend usar SQLite (modo dev).
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=
MYSQL_PORT=3306

# ---- Portas expostas no host ----
APAC_BACKEND_PORT=8000
APAC_FRONTEND_PORT=3000
